              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.order_id) pm.collectionVariables.set('order_id', json.order_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
